# Neon
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Neon Auth
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=

# Vercel Blob (Vercel Dashboard → Storage → Blob → read/write token) — image uploads only
BLOB_READ_WRITE_TOKEN=

# Together.ai — https://api.together.ai/ (used with Vercel AI SDK: `ai` + @ai-sdk/togetherai)
TOGETHER_API_KEY=

# Optional overrides (see src/lib/llm-recipe-fallback.ts)
# TOGETHER_TEXT_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo
# TOGETHER_VISION_MODEL=Llama-Vision-Free
